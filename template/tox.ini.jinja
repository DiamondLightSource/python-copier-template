[base]
name = {{ package_name }}
files = {[base]name} tests {% if sphinx %}docs/source/conf.py {% endif %}pyproject.toml README.md CHANGELOG.md

[tox]
envlist =
    check-packaging
    lint
    type-checking
    {{ 'py{' }}311,312,313}
    min_versions{% if sphinx %}
    docs
    docs-autobuild{% endif %}

minversion = 4.20{% if git_platform == 'github' %}

[gh-actions]
python =
  3.11: py311, lint, type-checking, min_versions
  3.12: py312, check-packaging
  3.13: py313{% if sphinx %}, docs{% endif %}{% endif %}

[testenv]
setenv =
    COVERAGE_FILE = {env:COVERAGE_FILE:.coverage-{envname}}
extras =
    test
commands =
    pytest \
        --basetemp={envtmpdir} \
        --cov={[base]name} \
        --cov-branch \
        --cov-fail-under=100 \
        --no-cov-on-fail \
        --cov-report term-missing \
        --cov-report html:reports/coverage-{envname} \
        --cov-report xml:reports/coverage-{envname}.xml \
        --html reports/pytest-{envname}.html \
        --junit-xml=reports/pytest-{envname}.xml \
        --self-contained-html \
        --durations 10 \
        --durations-min=2.0 \
        {posargs}

[testenv:check-packaging]
skip_install = true
deps =
    build
    twine
commands =
    python -m build -o {envtmpdir}/dist
    twine check {envtmpdir}/dist/*

[testenv:lint]
basepython = python3.11
deps =
    pre-commit
commands =
        pre-commit \
        run \
        --all-files

[testenv:format]
basepython = python3.11
skip_install = true
deps =
    codespell
    pre-commit
commands =
    codespell -i 3 -x .codespellignorelines -w {[base]files}
    pre-commit run --all-files

[testenv:type-checking]
extras = test
allowlist_externals = {{ type_checker }}
commands =
    "{{ type_checker }}" \
        {% if type_checker=="pyright" %}--pythonpath \
        {env:VIRTUAL_ENV}/bin/python \
        {% endif %}src \
        tests

[testenv:min_versions]
base_python = python3.11
allowlist_externals = uv
commands_pre =
    uv pip compile \
        --resolution lowest \
        --all-extras \
        --output-file {envtmpdir}/requirements_min.txt \
        pyproject.toml
    uv pip install -r {envtmpdir}/requirements_min.txt
    uv pip freeze

{% if sphinx %}[testenv:docs]
changedir = docs
extras = docs
commands =
    sphinx-build \
        --fresh-env \
        --show-traceback \
        --fail-on-warning \
        --keep-going \
        . \
        build/html

[testenv:docs-autobuild]
changedir = docs
extras = docs
commands =
    sphinx-autobuild \
        --show-traceback \
        --watch \
        ../README.md \
        . \
        build/html{% endif %}
